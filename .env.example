# Copy to .env and fill in. All keys are optional — Jarvis degrades to keyless
# public endpoints for anything it has no key for, and says so when asked.

# Alchemy — EVM RPC, Portfolio API, Prices API. https://dashboard.alchemy.com
ALCHEMY_API_KEY=

# Helius — Solana RPC, DAS, Enhanced Transactions. https://dashboard.helius.dev
HELIUS_API_KEY=

# Optional
# DUNE_API_KEY=
# ARKHAM_API_KEY=
